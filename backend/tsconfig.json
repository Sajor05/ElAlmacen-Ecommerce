{
  "compilerOptions": {
    /* Configuración Base */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Directorios */
    "rootDir": "..",
    "outDir": "./dist",

    /* Interoperabilidad */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
